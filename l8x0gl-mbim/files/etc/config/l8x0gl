config l8x0gl 'global'
	option enabled '1'
	option interface 'l8x0gl'
	option apn 'internet'
	option username ''
	option password ''
	option auth 'none'
	option iptype 'ipv4v6'
	option auto_setup_network '1'
	option auto_connect '1'
	option monitor_interval '15'
	option boot_debounce '12'
	option recovery_enabled '1'
	option max_soft_recovery '3'
	option allow_hard_reset '0'

config mbim 'mbim'
	option device 'auto'
	option data_interface 'auto'
	option use_proxy '1'
	option prefer_proxy_tools '1'

config esim 'esim'
	option enabled '1'
	option lpac_bin '/usr/bin/lpac-mbim'
	option non_disruptive_ops 'chip,profile-list,download,delete'
	option reconnect_on_switch 'auto'
	option operation_lock '/var/lock/l8x0gl-mbim.lock'
