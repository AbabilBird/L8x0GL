#!/bin/sh /etc/rc.common

START=90
STOP=15
USE_PROCD=1

. /usr/share/l8x0gl/lib.sh

start_service() {
	local enabled auto_setup auto_connect debounce
	enabled="$(uci_get global enabled 1)"
	[ "$enabled" = "1" ] || { log "service disabled by UCI"; return 0; }
	debounce="$(uci_get global boot_debounce 12)"
	log "waiting $debounce seconds for L850-GL USB re-enumeration"
	sleep "$debounce"
	/usr/share/l8x0gl/detect.sh >/dev/null 2>&1 || log "modem not ready yet"
	auto_setup="$(uci_get global auto_setup_network 1)"
	[ "$auto_setup" = "1" ] && { . /usr/share/l8x0gl/netifd.sh; setup_network >/dev/null 2>&1; } || true
	auto_connect="$(uci_get global auto_connect 1)"
	[ "$auto_connect" = "1" ] && ifup "$(uci_get global interface l8x0gl)" >/dev/null 2>&1 || true
	procd_open_instance l8x0gl-monitor
	procd_set_param command /usr/share/l8x0gl/monitor.sh
	procd_set_param respawn 30 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger l8x0gl
}
