#!/bin/sh /etc/rc.common

START=70
STOP=89
USE_PROCD=1

PROXY_BIN=""

find_proxy_bin() {
	for cand in /usr/libexec/mbim-proxy /usr/sbin/mbim-proxy /usr/lib/mbim-proxy /usr/bin/mbim-proxy; do
		[ -x "$cand" ] && { PROXY_BIN="$cand"; return 0; }
	done
	return 1
}

start_service() {
	if ! find_proxy_bin; then
		logger -t l8x0gl-mbim-proxy "mbim-proxy binary not found, skipping"
		return 0
	fi
	procd_open_instance l8x0gl-mbim-proxy
	procd_set_param command "$PROXY_BIN" --no-exit
	procd_set_param respawn 30 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
	logger -t l8x0gl-mbim-proxy "started $PROXY_BIN --no-exit"
}

reload_service() {
	stop
	sleep 1
	start
}
