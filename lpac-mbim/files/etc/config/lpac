config global 'global'
	option apdu_backend 'mbim'
	option http_backend 'curl'
	option apdu_debug '0'
	option http_debug '0'
	option custom_isd_r_aid 'A0000005591010FFFFFFFF8900000100'

config mbim 'mbim'
	option device 'auto'
	option proxy '1'
	option skip_slot_mapping '1'

config at 'at'
	option device 'auto'
	option debug '0'

config uqmi 'uqmi'
	option device 'auto'
	option debug '0'
